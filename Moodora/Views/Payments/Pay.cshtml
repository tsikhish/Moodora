@model Moodora.ViewModels.Payments.PaymentFormViewModel
@{
    ViewData["Title"] = "Demo Payment";
}

<div class="payment-hero mb-4">
    <div class="payment-hero-copy">
        <span class="payment-eyebrow">Demo checkout</span>
        <h1>Complete your payment</h1>
        <p>Use the test card numbers below to preview both payment outcomes. No external provider is contacted and no money is deducted.</p>
    </div>
    <div class="payment-total-card">
        <span>Amount</span>
        <strong>@Model.Amount.ToString("C")</strong>
        <small>Order @Model.OrderNumber</small>
    </div>
</div>

<div class="row g-4 align-items-start">
    <div class="col-lg-7">
        <div class="card payment-card shadow-sm">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="payment-chip-icon">💳</div>
                    <div>
                        <h2 class="h4 mb-1">Card details</h2>
                        <p class="text-muted mb-0">Only the last 4 digits are saved for the order receipt.</p>
                    </div>
                </div>

                <form asp-action="Pay" method="post" class="payment-form">
                    <input asp-for="OrderId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="mb-3">
                        <label asp-for="CardholderName" class="form-label"></label>
                        <input asp-for="CardholderName" class="form-control form-control-lg" autocomplete="cc-name" placeholder="Alex Morgan" />
                        <span asp-validation-for="CardholderName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CardNumber" class="form-label"></label>
                        <input asp-for="CardNumber" class="form-control form-control-lg payment-card-number" inputmode="numeric" autocomplete="cc-number" placeholder="4242 4242 4242 4242" />
                        <span asp-validation-for="CardNumber" class="text-danger"></span>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ExpiryDate" class="form-label"></label>
                            <input asp-for="ExpiryDate" class="form-control form-control-lg" autocomplete="cc-exp" placeholder="12/30" />
                            <span asp-validation-for="ExpiryDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SecurityCode" class="form-label"></label>
                            <input asp-for="SecurityCode" class="form-control form-control-lg" inputmode="numeric" autocomplete="cc-csc" placeholder="123" />
                            <span asp-validation-for="SecurityCode" class="text-danger"></span>
                        </div>
                    </div>
                    <button class="btn btn-primary btn-lg w-100 mt-4" type="submit">Pay @Model.Amount.ToString("C")</button>
                    <a class="btn btn-outline-secondary w-100 mt-2" asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId">Back to order</a>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card payment-card payment-summary shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Order summary</h2>
                <div class="order-summary-list">
                    @foreach (var item in Model.Items)
                    {
                        <div class="order-summary-item">
                            <img src="@(string.IsNullOrWhiteSpace(item.ProductImage) ? "https://placehold.co/96x96?text=Moodora" : item.ProductImage)" alt="@item.ProductName" />
                            <div class="flex-grow-1">
                                <div class="fw-semibold">@item.ProductName</div>
                                <div class="small text-muted">@item.Quantity × @item.UnitPrice.ToString("C")</div>
                            </div>
                            <strong>@item.LineTotal.ToString("C")</strong>
                        </div>
                    }
                </div>
                <div class="d-flex justify-content-between border-top pt-3 mt-3 fs-5">
                    <span>Total</span>
                    <strong>@Model.Amount.ToString("C")</strong>
                </div>
            </div>
        </div>

        <div class="payment-test-panel">
            <h3 class="h5">Test cards</h3>
            <div class="test-card-row success"><span>Successful payment</span><code>4242 4242 4242 4242</code></div>
            <div class="test-card-row failed"><span>Failed payment</span><code>4000 0000 0000 0002</code></div>
            <p class="small text-muted mb-0">Use any future expiry date and any 3 digit security code.</p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}