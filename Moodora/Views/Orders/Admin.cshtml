@model Moodora.ViewModels.Orders.AdminOrderListViewModel
@{
    ViewData["Title"] = "Admin Orders";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <p class="text-uppercase text-muted fw-semibold mb-1">Admin</p>
        <h1 class="mb-0">Order Management</h1>
    </div>
    <span class="badge bg-dark fs-6">@Model.Orders.Count order(s)</span>
</div>

<form method="get" class="filter-card mb-4">
    <div class="row g-2 align-items-center">
        <div class="col-md-4">
            <input name="Search" value="@Model.Query.Search" class="form-control" placeholder="Search order #, customer, email, city, or product" />
        </div>
        <div class="col-md-3">
            <select name="CustomerId" class="form-select" asp-items="ViewBag.Customers">
                <option value="">All customers</option>
            </select>
        </div>
        <div class="col-md-3">
            <select name="Status" class="form-select" asp-items="ViewBag.Statuses">
                <option value="">All order statuses</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="m-btn w-100">Filter</button>
        </div>
    </div>
</form>

@if (TempData["AdminOrderMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (!Model.Orders.Any())
{
    <div class="alert alert-info">No orders match your filters.</div>
}
else
{
    <div class="card order-card shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Customer</th>
                        <th>Delivery</th>
                        <th>Items</th>
                        <th>Payment Status</th>
                        <th>Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@order.OrderNumber</div>
                                <div class="small text-muted">@order.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                            </td>
                            <td>
                                <div>@order.FullName</div>
                                <div class="small text-muted">@order.Email</div>
                            </td>
                            <td>@order.City</td>
                            <td>@order.Items.Sum(x => x.Quantity)</td>
                            <td>
                                @{
                                    var paymentStatus = order.Payments
                                    .OrderByDescending(x => x.ProcessedAt ?? x.CreatedAt)
                                    .Select(x => x.Status)
                                    .FirstOrDefault(PaymentStatus.Pending);
                                }
                                <span class="badge payment-status-badge payment-status-@paymentStatus.ToString().ToLowerInvariant()">@paymentStatus</span>
                            </td>
                            <td class="fw-semibold">@order.TotalAmount.ToString("C")</td>
                            <td class="text-end"><a class="btn btn-outline-primary btn-sm" asp-action="AdminDetails" asp-route-id="@order.Id">View details</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}