@model IReadOnlyList<Moodora.Models.Order>

@{
    ViewData["Title"] = "Order History";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <p class="text-uppercase text-muted fw-semibold mb-1">Your purchases</p>
        <h1 class="mb-0">Order History</h1>
    </div>

    ```
    <a class="btn btn-primary"
       asp-controller="Products"
       asp-action="Index">
        Shop More
    </a>
    ```

</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You have not placed an order yet.
    </div>
}
else
{

    <div class="row g-3">

        ```
        @foreach (var order in Model)
        {
            <div class="col-12">

                <div class="card order-card shadow-sm">

                    <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">

                        <div>

                            <div class="fw-bold fs-5">
                                @(order.Items.FirstOrDefault()?.Product?.Name ?? "Product")
                            </div>

                            <div class="text-muted">
                                @order.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                • @order.Items.Count item(s)
                            </div>

                        </div>

                        <div class="text-lg-end">

                            <span class="badge status-badge status-@order.Status.ToString().ToLowerInvariant()">
                                @order.Status
                            </span>

                            <div class="fw-bold fs-5 mt-1">
                                @order.TotalAmount.ToString("C")
                            </div>

                        </div>

                        <a class="btn btn-outline-primary"
                           asp-action="Details"
                           asp-route-id="@order.Id">
                            Details
                        </a>

                    </div>

                </div>

            </div>
        }

</div>


}
