@model Moodora.ViewModels.Products.ProductListViewModel
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Products</h1>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-controller="Cart" asp-action="Index">🛒 My Cart</a>
        @if (User.IsInRole(ApplicationRoles.Admin))
        {
            <a class="btn btn-success" asp-action="Create">Create Product</a>
        }
    </div>
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-3"><input name="Search" value="@Model.Query.Search" class="form-control" placeholder="Search products" /></div>
    <div class="col-md-2">
        <select name="MoodCategoryId" class="form-select">
            <option value="">All moods</option>
            @foreach (var c in Model.MoodCategories)
            {
                <option value="@c.Id" selected="@(Model.Query.MoodCategoryId == c.Id)">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2"><input type="number" step="0.01" name="MinPrice" value="@Model.Query.MinPrice" class="form-control" placeholder="Min price" /></div>
    <div class="col-md-2"><input type="number" step="0.01" name="MaxPrice" value="@Model.Query.MaxPrice" class="form-control" placeholder="Max price" /></div>
    <div class="col-md-2">
        <select name="SortBy" class="form-select">
            <option value="created_desc">Newest</option>
            <option value="created_asc" selected="@(Model.Query.SortBy == "created_asc")">Oldest</option>
            <option value="price_asc" selected="@(Model.Query.SortBy == "price_asc")">Price low-high</option>
            <option value="price_desc" selected="@(Model.Query.SortBy == "price_desc")">Price high-low</option>
        </select>
    </div>
    <div class="col-md-1 form-check mt-2"><input name="InStockOnly" value="true" checked="@Model.Query.InStockOnly" type="checkbox" class="form-check-input" /><label class="form-check-label">Stock</label></div>
    <div class="col-12"><button class="btn btn-primary">Filter</button></div>
</form>
@if (TempData["CartMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["CartError"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row row-cols-1 row-cols-md-3 g-3">
    @foreach (var p in Model.Result.Items)
    {
        <div class="col">
            <div class="card h-100">
                <div class="card-body">
                    <h5>@p.Name</h5>
                    <p class="small text-muted">@string.Join(", ", p.ProductMoodCategories.Select(x => x.MoodCategory?.Name).Where(name => !string.IsNullOrWhiteSpace(name)))</p>
                    <p>@p.Description</p>
                    <p><strong>$@p.Price</strong> · Stock: @p.Stock</p>
                    <p>@(p.IsActive ? "Active" : "Inactive")</p>
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <a class="btn btn-outline-primary btn-sm" asp-action="Details" asp-route-id="@p.Id">Details</a>
                        <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex gap-1 align-items-center">
                            <input type="hidden" name="productId" value="@p.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <input class="form-control form-control-sm" style="width: 75px;" type="number" min="1" max="@p.Stock" name="quantity" value="1" aria-label="Quantity for @p.Name" />
                            <button type="submit" class="btn btn-primary btn-sm" @(p.Stock <= 0 ? "disabled" : null)>Add</button>
                        </form>
                        <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                            <input type="hidden" name="productId" value="@p.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <input type="hidden" name="returnUrl" value='@Url.Action("Checkout", "Orders")' />
                            <button type="submit" class="btn btn-success btn-sm" @(p.Stock <= 0 ? "disabled" : null)>Buy</button>
                        </form>
                    </div>
                    @if (User.IsInRole(ApplicationRoles.Admin))
                    {
                        <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@p.Id">Edit</a>
                        <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@p.Id">Delete</a>
                    }
                </div>
            </div>
        </div>
    }
</div>

<nav class="mt-3">
    <ul class="pagination">
        @for (var i = 1; i <= Model.Result.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Result.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-Page="@i" asp-route-Search="@Model.Query.Search" asp-route-MoodCategoryId="@Model.Query.MoodCategoryId" asp-route-MinPrice="@Model.Query.MinPrice" asp-route-MaxPrice="@Model.Query.MaxPrice" asp-route-SortBy="@Model.Query.SortBy" asp-route-InStockOnly="@Model.Query.InStockOnly">@i</a></li>
        }
    </ul>
</nav>