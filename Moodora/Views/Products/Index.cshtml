@model Moodora.ViewModels.Products.ProductListViewModel

@{
    ViewData["Title"] = "Products";
}

<section class="shelf-head">

    <p class="eyebrow">The mood shelf</p>

    <div class="d-flex flex-wrap justify-content-between gap-3 align-items-end">

        <div>
            <h1>Choose a feeling,<br />see your shelf</h1>
            <p class="lead">
                Tap a mood below. The shop rearranges itself around how you want to feel.
            </p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            @if (!User.IsInRole(ApplicationRoles.Admin))
            {
                <a class="btn btn-outline-primary"
                   asp-controller="Cart"
                   asp-action="Index">
                    🛒 My Cart
                </a>
            }

            @if (User.IsInRole(ApplicationRoles.Admin))
            {
                <a class="m-btn text-decoration-none"
                   asp-action="Create">
                    Create Product
                </a>
            }
        </div>

    </div>

    <div class="pill-row mt-4">

        <a class="pill @(Model.Query.MoodCategoryId == null ? "active" : "")"
           asp-action="Index">
            All
        </a>

        @foreach (var c in Model.MoodCategories)
        {
            <a class="pill @(Model.Query.MoodCategoryId == c.Id ? "active" : "")"
               asp-action="Index"
               asp-route-MoodCategoryId="@c.Id">
                @c.Name
            </a>
        }

    </div>

</section>

<form method="get" class="filter-card">

    <div class="row g-2 align-items-center">

        <div class="col-lg-3">
            <input name="Search"
                   value="@Model.Query.Search"
                   class="form-control"
                   placeholder="Search comforting goods" />
        </div>

        <div class="col-lg-2">
            <select name="MoodCategoryId" class="form-select">
                <option value="">All moods</option>
                @foreach (var c in Model.MoodCategories)
                {
                    <option value="@c.Id"
                            selected="@(Model.Query.MoodCategoryId == c.Id)">
                        @c.Name
                    </option>
                }
            </select>
        </div>

        <div class="col-lg-2">
            <input type="number"
                   step="0.01"
                   name="MinPrice"
                   value="@Model.Query.MinPrice"
                   class="form-control"
                   placeholder="Min price" />
        </div>

        <div class="col-lg-2">
            <input type="number"
                   step="0.01"
                   name="MaxPrice"
                   value="@Model.Query.MaxPrice"
                   class="form-control"
                   placeholder="Max price" />
        </div>
        @if (User.IsInRole(ApplicationRoles.Admin))
        {
            <div class="col-lg-2">
                <select name="IsActive" class="form-select">
                    <option value="">All statuses</option>
                    <option value="true" selected="@(Model.Query.IsActive == true)">Active</option>
                    <option value="false" selected="@(Model.Query.IsActive == false)">Inactive</option>
                </select>
            </div>
        }

        <div class="col-lg-2">
            <select name="SortBy" class="form-select">
                <option value="created_desc">Newest</option>
                <option value="created_asc"
                        selected="@(Model.Query.SortBy == "created_asc")">
                    Oldest
                </option>
                <option value="price_asc"
                        selected="@(Model.Query.SortBy == "price_asc")">
                    Price low-high
                </option>
                <option value="price_desc"
                        selected="@(Model.Query.SortBy == "price_desc")">
                    Price high-low
                </option>
            </select>
        </div>

        <div class="col-lg-1">
            <button class="m-btn w-100">Filter</button>
        </div>

    </div>

    <label class="form-check mt-3">
        <input name="InStockOnly"
               value="true"
               checked="@Model.Query.InStockOnly"
               type="checkbox"
               class="form-check-input" />
        In stock only
    </label>

</form>

@if (TempData["CartMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (TempData["CartError"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

@if (!Model.Result.Items.Any())
{
    <div class="m-card empty-state">
        <h3>No shelf items found</h3>
        <p class="lead">Try another mood or clear your filters.</p>
    </div>
}
<div class="product-grid">

    @foreach (var p in Model.Result.Items)
    {
        <div class="col">
            <div class="card h-100 product-card">

                @{
                    var productImageUrl = string.IsNullOrWhiteSpace(p.DisplayImageUrl)
                    ? "https://placehold.co/800x600?text=Moodora"
                    : p.DisplayImageUrl;
                }

                <div class="product-img">
                    <img src="@productImageUrl"
                         alt="@p.Name"
                         loading="lazy"
                         onerror="this.onerror=null;this.src='https://placehold.co/800x600?text=Moodora';" />
                </div>

                <div class="card-body">

                    <h5>@p.Name</h5>

                    <p class="small text-muted">
                        @string.Join(", ",
                        p.ProductMoodCategories
                        .Select(x => x.MoodCategory?.Name)
                        .Where(name => !string.IsNullOrWhiteSpace(name)))
                </p>

                <p>@p.Description</p>

                <p>
                    <strong>$@p.Price</strong>
                    · Stock: @p.Stock
                </p>

                <p>
                    @(p.IsActive ? "Active" : "Inactive")
                </p>

                <div class="d-flex flex-wrap gap-2 align-items-center">

                    <a class="btn btn-outline-primary btn-sm"
                       asp-action="Details"
                       asp-route-id="@p.Id">
                        Details
                    </a>

                    @if (User.IsInRole(ApplicationRoles.Admin))
                        {
                            <a class="btn btn-outline-secondary btn-sm"
                               asp-action="Edit"
                               asp-route-id="@p.Id">
                                Edit
                            </a>

                            <a class="btn btn-outline-danger btn-sm"
                               asp-action="Delete"
                               asp-route-id="@p.Id">
                                Delete
                            </a>
                        }
                        else
                        {
                            <form asp-controller="Cart"
                                  asp-action="Add"
                                  method="post"
                                  class="d-flex gap-1 align-items-center">

                                <input type="hidden"
                                       name="productId"
                                       value="@p.Id" />

                                <input type="hidden"
                                       name="returnUrl"
                                       value="@Context.Request.Path@Context.Request.QueryString" />

                                <input class="form-control form-control-sm"
                                       style="width:75px;"
                                       type="number"
                                       min="1"
                                       max="@p.Stock"
                                       name="quantity"
                                       value="1"
                                       aria-label="Quantity for @p.Name" />

                                <button type="submit"
                                        class="btn btn-primary btn-sm"
                                        disabled="@(p.Stock <= 0)">
                                    Add
                                </button>

                            </form>

                            <form asp-controller="Cart"
                                  asp-action="Add"
                                  method="post"
                                  class="d-inline">

                                <input type="hidden"
                                       name="productId"
                                       value="@p.Id" />

                                <input type="hidden"
                                       name="quantity"
                                       value="1" />

                                <input type="hidden"
                                       name="returnUrl"
                                       value='@Url.Action("Checkout", "Orders")' />

                                <button type="submit"
                                        class="btn btn-success btn-sm"
                                        disabled="@(p.Stock <= 0)">
                                    Buy
                                </button>

                            </form>
                        }

                    </div>

                </div>

            </div>
        </div>
    }

</div>

<nav class="mt-4">
    <ul class="pagination">

        @for (var i = 1; i <= Model.Result.TotalPages; i++)
        {
                    <li class="page-item @(i == Model.Result.Page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-Page="@i"
                           asp-route-Search="@Model.Query.Search"
                           asp-route-MoodCategoryId="@Model.Query.MoodCategoryId"
                           asp-route-MinPrice="@Model.Query.MinPrice"
                           asp-route-MaxPrice="@Model.Query.MaxPrice"
                           asp-route-SortBy="@Model.Query.SortBy"
                           asp-route-InStockOnly="@Model.Query.InStockOnly"
                           asp-route-IsActive="@Model.Query.IsActive">
                            @i
                        </a>
                    </li>
        }

    </ul>
</nav>