@{
    ViewData["Title"] = "Moodora";
}

<section class="py-5 text-center">
    <div class="container">
        <h1 class="display-3 fw-bold text-primary">Moodora</h1>
        <p class="lead text-muted mx-auto" style="max-width: 720px;">
            Discover products organized by mood, explore curated categories, and manage your collection from one simple place.
        </p>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="d-flex justify-content-center gap-2 flex-wrap mt-4">
                <a class="btn btn-primary btn-lg" asp-controller="Products" asp-action="Index">View Products</a>
                <a class="btn btn-outline-primary btn-lg" asp-controller="MoodCategories" asp-action="Index">View Mood Categories</a>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-center gap-2 flex-wrap mt-4">
                <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Login">Log in</a>
                <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Register">Create Account</a>
            </div>
            <p class="text-muted mt-3 mb-0">Log in to see products and mood categories.</p>
        }
    </div>
</section>