@{
    ViewData["Title"] = "Moodora";
}

<section class="hero">

    <div class="hero-copy">

        <div class="pill d-inline-flex gap-2 mb-4">
            ⌁ THE MOOD-BASED ONLINE SHOP
        </div>

        <h1>
            Shop how you <em style="color:#ad5520">feel</em> today.
        </h1>

        <p class="lead mt-4">
            Discover products that match your mood. Simply choose how you feel and Moodora will curate personalized recommendations just for you
        </p>

        <div class="d-flex gap-2 flex-wrap mt-4">

            <a class="m-btn text-decoration-none"
               asp-controller="Products"
               asp-action="Index">
                Pick your mood →
            </a>

            <a class="btn btn-outline-primary" href="#how-it-works">
                How it works
            </a>

        </div>

        <div class="d-flex gap-5 mt-5">

            <div>
                <h3 class="mb-0">5+</h3>
                <span class="text-muted">curated moods</span>
            </div>

            <div>
                <h3 class="mb-0">100+</h3>
                <span class="text-muted">handpicked goods</span>
            </div>

            <div>
                <h3 class="mb-0">4.9</h3>
                <span class="text-muted">avg. rating</span>
            </div>

        </div>

    </div>

    <div class="hero-image">

        <div class="hero-frame">
            <img src="https://images.unsplash.com/photo-1602874801007-bd458bb1b8b6?auto=format&fit=crop&w=1000&q=80"
                 alt="Warm cozy shelf with candle, mug, book and textile" />
        </div>

        <div class="hero-badge">
            <div class="eyebrow">Today's mood</div>
            <h4 class="mb-0">Warm & cozy</h4>
        </div>

    </div>

</section>

<div class="mood-strip">
    <span>Calm</span><i>•</i>
    <span>Cozy</span><i>•</i>
    <span>Energized</span><i>•</i>
    <span>Joyful</span><i>•</i>
    <span>Focused</span><i>•</i>
    <span>Romantic</span><i>•</i>
    <span>Playful</span><i>•</i>
    <span>Grounded</span><i>•</i>
    <span>Dreamy</span><i>•</i>
    <span>Refreshed</span>
</div>

<section id="how-it-works" class="py-5">

    <p class="eyebrow">The Mood Shelf</p>

    <h2>Choose a feeling, see your shelf.</h2>

    <div class="steps mt-4">
        <div>
            <strong class="text-primary">01.</strong>
            <h5 class="mt-2">Tell us how you feel</h5>
            <p class="text-muted">
                Your mood is the starting point of the journey.
            </p>
        </div>

        <div>
            <strong class="text-primary">02.</strong>
            <h5 class="mt-2">Explore your mood shelf</h5>
            <p class="text-muted">
                Discover products thoughtfully selected to match your vibe.
            </p>
        </div>

        <div>
            <strong class="text-primary">03.</strong>
            <h5 class="mt-2">Find what feels right</h5>
            <p class="text-muted">
                Choose your favorites and enjoy a more personal shopping experience.
            </p>
        </div>
    </div>
</section>