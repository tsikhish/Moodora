<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Moodora</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Moodora.styles.css" asp-append-version="true" />
</head>

<body>

    <div class="moodora-shell">

        <header class="moodora-nav sticky-top">

            <nav class="navbar navbar-expand-lg h-100 p-0">

                <div class="moodora-container d-flex align-items-center">

                    <a class="navbar-brand brand"
                       asp-controller="Moodora"
                       asp-action="Index">
                        Moodora
                    </a>

                    <button class="navbar-toggler"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#moodoraNav"
                            aria-controls="moodoraNav"
                            aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse gap-lg-3" id="moodoraNav">
                        <ul class="navbar-nav primary-nav mx-lg-auto">
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Products"
                                   asp-action="Index">
                                    Shop
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Moodora"
                                   asp-action="Index"
                                   asp-fragment="how-it-works">
                                    How it works
                                </a>
                            </li>

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="MoodCategories"
                                       asp-action="Index">
                                        Mood Categories
                                    </a>
                                </li>
                            @if (!User.IsInRole(ApplicationRoles.Admin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Orders"
                                       asp-action="History">
                                        Order History
                                    </a>
                                </li>
                            }
                                @if (!User.IsInRole(ApplicationRoles.Admin))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link"
                                           asp-controller="Cart"
                                           asp-action="Index">
                                            Cart
                                        </a>
                                    </li>
                                }
                            }

                        </ul>

                        @if (User.IsInRole(ApplicationRoles.Admin))
                        {
                            <ul class="navbar-nav admin-nav align-items-lg-center">
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Orders"
                                       asp-action="Admin">
                                        Customer Orders
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Products"
                                       asp-action="Create">
                                        Add Product
                                    </a>
                                </li>
                            </ul>
                        }

                        <ul class="navbar-nav user-nav align-items-lg-center ms-lg-auto">

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <span class="nav-link">
                                        @User.Identity?.Name
                                    </span>
                                </li>

                                <li class="nav-item">
                                    <form asp-controller="Account"
                                          asp-action="Logout"
                                          method="post">
                                        <button class="nav-link btn btn-link border-0"
                                                type="submit">
                                            Logout
                                        </button>
                                    </form>
                                </li>

                                <li class="nav-item ms-lg-2">
                                    <a class="m-btn text-decoration-none"
                                       asp-controller="Products"
                                       asp-action="Index">
                                        ▣ Start shopping
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Account"
                                       asp-action="Login">
                                        Login
                                    </a>
                                </li>

                                <li class="nav-item ms-lg-2">
                                    <a class="m-btn text-decoration-none"
                                       asp-controller="Account"
                                       asp-action="Register">
                                        ▣ Create Account
                                    </a>
                                </li>
                            }

                        </ul>

                    </div>

                </div>

            </nav>

        </header>

        <main role="main" class="moodora-main">

            <div class="moodora-container">
                @RenderBody()
            </div>

        </main>

        <footer class="moodora-footer">

            <div class="moodora-container d-flex flex-wrap justify-content-between gap-2">
                <span>&copy; 2026 Moodora</span>
                <span>Mood-based online shop</span>
            </div>

        </footer>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>