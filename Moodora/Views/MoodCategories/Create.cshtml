@model Moodora.Models.MoodCategory

@{
    ViewData["Title"] = "Create Mood Category";
}

<section class="shelf-head">
    <p class="eyebrow">Admin panel</p>
    <h1>Create mood</h1>
</section>

<form asp-action="Create" class="m-card detail-panel row g-3">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-lg-7">

        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control mb-3" />
        <span asp-validation-for="Name" class="text-danger"></span>

        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control mb-3"></textarea>

        <label asp-for="ImageUrl"></label>
        <input asp-for="ImageUrl"
               class="form-control js-image-input"
               data-preview="mood-preview" />
        <span asp-validation-for="ImageUrl" class="text-danger"></span>

        <div class="form-check mt-3">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>

    </div>

    <div class="col-lg-5">
        <div id="mood-preview" class="image-preview"></div>
    </div>

    <div class="col-12 d-flex gap-2">
        <button class="m-btn">Create</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}