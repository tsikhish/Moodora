@model Moodora.Models.MoodCategory

@{
    ViewData["Title"] = Model.Name;
}

<section class="detail-grid">

    <img class="product-detail-image"
         src="@(string.IsNullOrWhiteSpace(Model.ImageUrl)
                         ? "https://images.unsplash.com/photo-1515378791036-0648a3ef77b2?auto=format&fit=crop&w=1000&q=80"
                         : Model.ImageUrl)"
         alt="@Model.Name" />

    <div class="m-card detail-panel">

        <p class="eyebrow">Mood collection</p>

        <h1>@Model.Name</h1>

        <p class="lead">@Model.Description</p>

        <p>
            <strong>@Model.ProductMoodCategories.Count</strong> linked products ·
            @(Model.IsActive ? "Active" : "Paused")
        </p>

        <dt class="col-sm-2">Products</dt>
        <dd class="col-sm-10">@Model.ProductMoodCategories.Count</dd>

            @if (User.IsInRole(ApplicationRoles.Admin))
            {
                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="m-btn text-decoration-none">
                    Edit
                </a>
            }

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>

        </div>

    </div>

</section>